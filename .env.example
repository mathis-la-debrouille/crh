# Copy this file to .env.local and fill in all values before running.
# Never commit .env.local to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite
DATABASE_URL="file:./dev.db"
# Production (Turso): libsql://your-db.turso.io
# DATABASE_URL="libsql://your-db-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"  # Set to your production URL when deploying

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# https://console.twilio.com/ → Account Info
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="+1XXXXXXXXXX"  # Your Twilio WhatsApp-enabled number

# ── Admin ─────────────────────────────────────────────────────────────────────
# Google email of the admin account — server-only, never prefix with NEXT_PUBLIC
ADMIN_EMAIL=""

# ── Claude API (per-user, stored in DB — this is the fallback / default) ──────
# ANTHROPIC_API_KEY=""
