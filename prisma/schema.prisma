generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?

  // Google OAuth tokens — kept for backward compat; authoritative copy is on EmailAccount
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleConnected    Boolean  @default(false)

  // WhatsApp
  whatsappNumber    String?
  whatsappConnected Boolean @default(false)

  // AI (Claude)
  claudeApiKey String?
  ruleContext  String  @default("")
  userContext  String  @default("")

  // Preferences
  timezone String @default("Europe/Paris")

  // Onboarding state machine
  onboardingStep  String    @default("new")   // "new" | "profile" | "brief" | "done"
  writingStyle    String    @default("")
  styleAnalyzedAt DateTime?

  // Assistant behavior (user-configurable)
  assistantPaused Boolean @default(false)
  tone            String  @default("formal")
  register        String  @default("vous")
  language        String  @default("fr")
  signature       String  @default("")
  guardrails      String  @default("[]")

  // Daily brief
  dailyBriefEnabled  Boolean   @default(false)
  dailyBriefTime     String?
  dailyBriefLastSent DateTime?

  // Inbox watch (master toggle; per-account flag lives on EmailAccount)
  inboxWatchEnabled      Boolean   @default(false)
  inboxWatchIntervalMins Int       @default(15)
  inboxWatchLastChecked  DateTime?

  // Account status
  status        String  @default("active")
  phoneVerified Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messages      WhatsAppMessage[]
  reminders     Reminder[]
  actions       AgentAction[]
  contacts      Contact[]
  emailAccounts EmailAccount[]
}

model EmailAccount {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  provider  String  @default("google")
  email     String
  label     String
  isPrimary Boolean @default(false)
  connected Boolean @default(true)

  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?

  displayName String?
  signature   String?
  language    String?
  styleNotes  String?
  workContext String?

  inboxWatchEnabled     Boolean   @default(false)
  inboxWatchLastChecked DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, email])
  @@index([userId])
}

model AllowedNumber {
  id        String   @id @default(cuid())
  phone     String   @unique
  note      String?
  createdAt DateTime @default(now())
}

model OtpCode {
  id           String   @id @default(cuid())
  phone        String
  code         String
  expiresAt    DateTime
  attempts     Int      @default(0)
  used         Boolean  @default(false)
  sessionToken String?  @unique
  createdAt    DateTime @default(now())

  @@index([phone])
}

model Contact {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  displayName        String
  aliases            String    @default("[]")
  emails             String    @default("[]")
  relationship       String?
  register           String?
  org                String?
  role               String?
  toneNotes          String?
  notes              String?
  lastInteraction    DateTime?
  emailCount         Int       @default(0)
  preferredAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AgentAction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  kind         String
  refId        String?
  summary      String
  accountEmail String?

  createdAt DateTime @default(now())
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  message     String
  scheduledAt DateTime
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model WhatsAppMessage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  direction       String
  body            String
  from            String
  to              String
  sid             String?
  timestamp       DateTime @default(now())
  inputTokens     Int?
  outputTokens    Int?
  model           String?
  agentIterations Int?
  latencyMs       Int?
  replyOverBudget Boolean?

  @@index([userId])
  @@index([timestamp])
}

model JobRun {
  id         String   @id @default(cuid())
  job        String
  userId     String?
  status     String
  error      String?
  durationMs Int?
  ranAt      DateTime @default(now())

  @@index([job])
  @@index([ranAt])
}

model ToolCallLog {
  id        String   @id @default(cuid())
  userId    String
  tool      String
  success   Boolean
  errorMsg  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tool])
  @@index([createdAt])
}
